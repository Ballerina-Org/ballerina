<Project>
    <PropertyGroup>
        <!--
            Vendored local embeddings assets in build/resources/LocalEmbeddingsModel/default
            were sourced from https://huggingface.co/SmartComponents/bge-micro-v2 at
            revision 7ec22bc:
              - onnx/model_quantized.onnx -> model.onnx
              - vocab.txt -> vocab.txt
        -->
        <LocalEmbeddingsModelName Condition="'$(LocalEmbeddingsModelName)' == ''">default</LocalEmbeddingsModelName>
        <LocalEmbeddingsModelResourcesDir>$(MSBuildThisFileDirectory)resources\LocalEmbeddingsModel\$(LocalEmbeddingsModelName)\</LocalEmbeddingsModelResourcesDir>
        <LocalEmbeddingsModelPath Condition="'$(LocalEmbeddingsModelPath)' == ''">$(LocalEmbeddingsModelResourcesDir)model.onnx</LocalEmbeddingsModelPath>
        <LocalEmbeddingsVocabPath Condition="'$(LocalEmbeddingsVocabPath)' == ''">$(LocalEmbeddingsModelResourcesDir)vocab.txt</LocalEmbeddingsVocabPath>
    </PropertyGroup>

    <Target Name="ValidateLocalEmbeddingsContentFiles" BeforeTargets="AssignTargetPaths">
        <Error Condition="!Exists('$(LocalEmbeddingsModelPath)')"
               Text="Local embeddings model file not found: $(LocalEmbeddingsModelPath). Ensure vendored resources exist under build/resources/LocalEmbeddingsModel/$(LocalEmbeddingsModelName)/." />
        <Error Condition="!Exists('$(LocalEmbeddingsVocabPath)')"
               Text="Local embeddings vocab file not found: $(LocalEmbeddingsVocabPath). Ensure vendored resources exist under build/resources/LocalEmbeddingsModel/$(LocalEmbeddingsModelName)/." />
    </Target>

    <Target Name="AttachEmbeddingsContentFiles" BeforeTargets="AssignTargetPaths">
        <ItemGroup>
            <Content CopyToOutputDirectory="PreserveNewest"
                     Include="$(LocalEmbeddingsModelPath)"
                     TargetPath="LocalEmbeddingsModel\$(LocalEmbeddingsModelName)\model.onnx" />
            <Content CopyToOutputDirectory="PreserveNewest"
                     Include="$(LocalEmbeddingsVocabPath)"
                     TargetPath="LocalEmbeddingsModel\$(LocalEmbeddingsModelName)\vocab.txt" />
        </ItemGroup>
    </Target>
</Project>
