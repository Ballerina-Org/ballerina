<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="Golang/Syntax.fs" />
    <Compile Include="Golang/Model.fs" />
    <Compile Include="Golang/Header.fs" />
    <Compile Include="Golang/Patterns.fs" />
    <Compile Include="Golang/TopLevelType.fs" />
    <Compile Include="Golang/SerializationTypes.fs" />
    <Compile Include="Golang/Common.fs" />
    <Compile Include="Golang/RecordSerialization.fs" />
    <Compile Include="Golang/UnionSerialization.fs" />
    <Compile Include="Golang/Serialization.fs" />
    <Compile Include="Golang/Context.fs" />
    <Compile Include="Golang/Enum.fs" />
    <Compile Include="Golang/Union.fs" />
    <Compile Include="Golang/Record.fs" />
    <Compile Include="Golang/CustomTypes.fs" />
    <Compile Include="Python/Syntax.fs" />
    <Compile Include="Python/Model.fs" />
    <Compile Include="Python/Header.fs" />
    <Compile Include="Python/Parsing.fs" />
    <Compile Include="Python/Patterns.fs" />
    <Compile Include="Python/ParsingTypes.fs" />
    <Compile Include="Python/PyId.fs" />
    <Compile Include="Python/Record.fs" />
    <Compile Include="Python/Union.fs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../ballerina-cat/ballerina-cat.fsproj" />
    <ProjectReference Include="../ballerina-stdlib/ballerina-stdlib.fsproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="FSharp.SystemTextJson" Version="1.4.36" />
  </ItemGroup>
</Project>