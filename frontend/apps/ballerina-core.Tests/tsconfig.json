{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "src/*": ["../../libraries/ballerina-core/src/*"],
      "ballerina-core": ["../../libraries/ballerina-core/main.ts"],
      "ballerina-core/*": ["../../libraries/ballerina-core/*"]
    }
  },
  "include": ["tests/**/*.ts", "tests/**/*.d.ts"]
}
