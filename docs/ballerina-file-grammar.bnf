<program> ::= <top-level-seq>

<top-level-seq> ::= <top-level-item>
                  | <top-level-item> <top-level-seq>

<top-level-item> ::= <type-decl> ";"
                   | <top-level-let-decl>
                   | <expr>

<top-level-let-decl> ::= "let" <expr-let-pattern> <expr-let-type-annotation-opt> "=" <expr> ";"

<type-decl> ::= "type" <id> "=" <type-expr>

<type-expr> ::= <primitive-type>
              | <record-type>
              | <sum-type>
              | <tuple-type>
              | <arrow-type>
              | <union-type>
              | <lookup-type>
              | <apply-type>
              | <schema-type>
              | "(" <type-expr> ")"

<primitive-type> ::= "()"
                   | "guid"
                   | "int"
                   | "number"
                   | "int32"
                   | "int64"
                   | "float32"
                   | "float64"
                   | "decimal"
                   | "bool"
                   | "boolean"
                   | "string"
                   | "date"
                   | "dateOnly"
                   | "dateTime"
                   | "timeSpan"
                   | "vector"

<record-type> ::= "{" <record-field-list> "}"

<record-field-list> ::= <record-field>
                      | <record-field> ";" <record-field-list>
                      | <record-field> ";"

<record-field> ::= <id> ":" <type-expr>

<sum-type> ::= "|" <sum-case-list>
<sum-case-list> ::= <sum-case>
                  | <sum-case> "|" <sum-case-list>
<sum-case> ::= <id> "of" <type-expr>
             | <id> "of" "(" <type-expr-list> ")"

<tuple-type> ::= <type-expr> "*" <type-expr>
               | <type-expr> "*" <tuple-type>

<arrow-type> ::= <type-expr> "->" <type-expr>

<union-type> ::= <type-expr> "+" <type-expr>
               | <type-expr> "+" <union-type>

<lookup-type> ::= <qualified-id>

<apply-type> ::= <qualified-id> "[" <type-expr-list> "]"

<type-expr-list> ::= <type-expr>
                   | <type-expr> "," <type-expr-list>

<schema-type> ::= "schema" "{" <schema-non-include-item-list-opt> "}"
                | "schema" "{" <schema-non-include-item-list-opt> <schema-include> <schema-non-include-item-list-opt> "}"

<schema-non-include-item-list-opt> ::= <empty>
                                     | <schema-non-include-item-list>

<schema-non-include-item-list> ::= <schema-non-include-item>
                                 | <schema-non-include-item> <schema-non-include-item-list>

<schema-non-include-item> ::= <entity-decl>
                            | <relation-decl>

<schema-include> ::= "include" <qualified-id> <schema-include-with-opt>

<schema-include-with-opt> ::= <empty>
                            | "with" "{" <schema-include-item-list> "}"

<schema-include-item-list> ::= <schema-include-item>
                             | <schema-include-item> <schema-include-item-list>

<schema-include-item> ::= <entity-decl>
                        | <relation-decl>

<entity-decl> ::= "entity" <id> "{" <entity-item-list> "}"

<entity-item-list> ::= <entity-item>
                     | <entity-item> <entity-item-list>

<entity-item> ::= "type" <qualified-id> <qualified-id>
                | <entity-hook-let-decl>

<relation-decl> ::= "relation" <id> "{" "from" <qualified-id> "to" <qualified-id> "cardinality" <cardinality> "}"

<cardinality> ::= "1..1"
                | "1..*"
                | "0..1"
                | "0..*"
                | "*..1"
                | "*..*"

<entity-hook-let-decl> ::= "let" <entity-hook-pattern> "=" <expr>

<entity-hook-pattern> ::= "on" <hook-kind>
                        | "can" <permission-kind>

<expr-let-pattern> ::= <id>

<expr-let-type-annotation-opt> ::= <empty>
                                 | ":" <type-expr>

<hook-kind> ::= "creating" | "created" | "updating" | "updated" | "deleting" | "deleted"
<permission-kind> ::= "read" | "create" | "update" | "delete"

<expr> ::= <let-expr>
         | <if-expr>
         | <match-expr>
         | <query-expr>
         | <lambda-expr>
         | <expr-binary-expr>

<let-expr> ::= "let" <expr-let-pattern> <expr-let-type-annotation-opt> "=" <expr> "in" <expr>
             | "let" <expr-let-pattern> <expr-let-type-annotation-opt> "=" <expr> ";" <expr>

<if-expr> ::= "if" <expr> "then" <expr> "else" <expr>

<match-expr> ::= "match" <expr> "with" <match-case-list>
<match-case-list> ::= <match-case>
                    | <match-case> <match-case-list>
<match-case> ::= "|" <pattern> "->" <expr>

<query-expr> ::= "query" "{" <query-body> "}"

<query-body> ::= <query-from-clause>
               | <query-from-clause> <query-join-clauses> <query-select-tail>
               | <query-from-clause> <query-select-tail>

<query-from-clause> ::= "from" <query-source-list>

<query-source-list> ::= <query-source-binding>
                      | <query-source-binding> "," <query-source-list>

<query-source-binding> ::= <id> "in" <query-inner-expr>

<query-join-clauses> ::= <query-join-clause>
                       | <query-join-clause> <query-join-clauses>

<query-join-clause> ::= "join" "on" <query-join-condition>

<query-join-condition> ::= "(" <query-inner-expr> "," <query-inner-expr> ")"
                         | "(" <query-inner-expr> "," <query-inner-expr> ")" "and" <query-join-condition>

<query-select-tail> ::= <query-where-clauses> "select" <query-inner-expr> <query-orderby-opt>
                      | "select" <query-inner-expr> <query-orderby-opt>

<query-where-clauses> ::= <query-where-clause>
                        | <query-where-clause> <query-where-clauses>

<query-where-clause> ::= "where" <query-inner-expr>

<query-orderby-opt> ::= <empty>
                      | "orderby" "(" <query-orderby-list> ")"

<query-orderby-list> ::= <query-orderby-item>
                       | <query-orderby-item> "," <query-orderby-list>

<query-orderby-item> ::= <query-inner-expr>
                       | <query-inner-expr> "asc"
                       | <query-inner-expr> "desc"

// Query inner expressions intentionally exclude <match-expr> so where/select clauses
// cannot contain match blocks.
<query-inner-expr> ::= <query-logical-expr>

<query-logical-expr> ::= <query-comparison-expr> <query-logical-tail-opt>

<query-logical-tail-opt> ::= <empty>
                          | <query-logical-op> <query-comparison-expr> <query-logical-tail-opt>

<query-logical-op> ::= "&&"
                     | "||"

<query-comparison-expr> ::= <query-additive-expr> <query-comparison-tail-opt>

<query-comparison-tail-opt> ::= <empty>
                             | <query-comparison-op> <query-additive-expr> <query-comparison-tail-opt>

<query-comparison-op> ::= "=="
                        | "!="
                        | ">"
                        | "<"
                        | ">="
                        | "<="

<query-additive-expr> ::= <query-multiplicative-expr> <query-additive-tail-opt>

<query-additive-tail-opt> ::= <empty>
                           | <query-additive-op> <query-multiplicative-expr> <query-additive-tail-opt>

<query-additive-op> ::= "+"
                      | "-"

<query-multiplicative-expr> ::= <query-app-expr> <query-multiplicative-tail-opt>

<query-multiplicative-tail-opt> ::= <empty>
                                 | <query-multiplicative-op> <query-app-expr> <query-multiplicative-tail-opt>

<query-multiplicative-op> ::= "*"
                            | "/"
                            | "%"

<query-app-expr> ::= <query-atomic-expr>
                   | <query-atomic-expr> <query-app-expr>

<query-atomic-expr> ::= <qualified-id>
                      | <literal>
                      | "(" <query-inner-expr> ")"
                      | <query-subquery-expr>
                      | <query-unary-subquery-expr>

<query-subquery-expr> ::= "query" "{" <query-body> "}"

<query-unary-subquery-expr> ::= "exists" <query-subquery-expr>
                              | "count" <query-subquery-expr>
                              | "array" <query-subquery-expr>

<query-record-value-fields> ::= <query-record-value-field>
                              | <query-record-value-field> ";" <query-record-value-fields>
                              | <query-record-value-field> ";"

<query-record-value-field> ::= <qualified-id> "=" <query-inner-expr>

<lambda-expr> ::= "fun" "(" <lambda-params> ")" "->" <expr>
<lambda-params> ::= <lambda-param>
                  | <lambda-param> <lambda-params>
                  | <empty>
<lambda-param> ::= "(" <id> ":" <type-expr> ")"

<expr-binary-expr> ::= <expr-logical-expr>

<expr-logical-expr> ::= <expr-comparison-expr> <expr-logical-tail-opt>

<expr-logical-tail-opt> ::= <empty>
                         | <expr-logical-op> <expr-comparison-expr> <expr-logical-tail-opt>

<expr-logical-op> ::= "&&"
                    | "||"

<expr-comparison-expr> ::= <expr-additive-expr> <expr-comparison-tail-opt>

<expr-comparison-tail-opt> ::= <empty>
                            | <expr-comparison-op> <expr-additive-expr> <expr-comparison-tail-opt>

<expr-comparison-op> ::= "=="
                       | "!="
                       | ">"
                       | "<"
                       | ">="
                       | "<="

<expr-additive-expr> ::= <expr-multiplicative-expr> <expr-additive-tail-opt>

<expr-additive-tail-opt> ::= <empty>
                          | <expr-additive-op> <expr-multiplicative-expr> <expr-additive-tail-opt>

<expr-additive-op> ::= "+"
                     | "-"

<expr-multiplicative-expr> ::= <expr-composition-expr> <expr-multiplicative-tail-opt>

<expr-multiplicative-tail-opt> ::= <empty>
                                | <expr-multiplicative-op> <expr-composition-expr> <expr-multiplicative-tail-opt>

<expr-multiplicative-op> ::= "*"
                           | "/"
                           | "%"

<expr-composition-expr> ::= <app-expr> <expr-composition-tail-opt>

<expr-composition-tail-opt> ::= <empty>
                              | <expr-composition-op> <app-expr> <expr-composition-tail-opt>

<expr-composition-op> ::= "|>"
                        | ">>"

<app-expr> ::= <atomic-expr>
             | <atomic-expr> <atomic-expr>

<atomic-expr> ::= <qualified-id>
                | <literal>
                | "(" <expr> ")"
                | "{" <record-value-fields> "}"

<record-value-fields> ::= <record-value-field>
                        | <record-value-field> ";" <record-value-fields>
                        | <record-value-field> ";"

<record-value-field> ::= <qualified-id> "=" <expr>

<pattern> ::= <id>
            | "_"
            | <qualified-id>
            | "(" <pattern> ")"

<qualified-id> ::= <id>
                 | <id> "::" <qualified-id>
                 | <qualified-id> "." <id>

<id> ::= <identifier-token>

<literal> ::= <int-literal>
            | <float-literal>
            | <decimal-literal>
            | <string-literal>
            | "true"
            | "false"

<empty> ::= 

// Notes:
// 1) This BNF is an authoritative reference for repo .bl files, aligned with the Next parser.
// 2) Canonical optional-value encoding is via unions: () + T (not with '?').
// 3) Imports are intentionally omitted: current repo BL files do not use import declarations.
// 4) Exact operator precedence and some advanced constructs are implemented by parser combinators.
