{
  "name": "bl-language-tools",
  "displayName": "Ballerina Language Tools",
  "description": "Syntax highlighting and diagnostics for .bl projects using bise-sql server mode",
  "version": "0.0.1",
  "publisher": "GiuseppeMaggiore",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ballerina-Org/ballerina"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:**/*.blproj"
  ],
  "contributes": {
    "languages": [
      {
        "id": "bl",
        "aliases": [
          "BL",
          "Ballerina DSL"
        ],
        "extensions": [
          ".bl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bl",
        "scopeName": "source.bl",
        "path": "./syntaxes/bl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "bl.buildActiveProject",
        "title": "BL: Build Active Project"
      },
      {
        "command": "bl.showBuildOrder",
        "title": "BL: Show Active Project Build Order"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package:vsix": "npx @vscode/vsce package",
    "publish:pre": "npx @vscode/vsce publish --pre-release",
    "publish:stable": "npx @vscode/vsce publish",
    "publish:patch": "npx @vscode/vsce publish patch"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.92.0",
    "typescript": "^5.5.4"
  }
}
